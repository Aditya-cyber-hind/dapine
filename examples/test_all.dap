pipeline full_power_test() {
    read "houses.csv" as raw
    print raw
    stats raw
    
    filter raw where price > 300000 as expensive
    mutate expensive add price_per_sqft = price / sqft as with_metric
    sort with_metric by price_per_sqft desc as sorted
    
    group sorted by bedrooms [
        count(price) as homes,
        avg(price) as avg_price,
        avg(price_per_sqft) as avg_ppsf
    ] as results
    
    print results
    
    write results into "report.json"
    excel write results into "output.xlsx"
    report results as "House Price Analysis" into "analysis.md"
    chart results avg_price by bedrooms as bar into "chart.html"
}