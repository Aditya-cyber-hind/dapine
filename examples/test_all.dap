func double(x) = x * 2
func triple(x) = x * 3

pipeline dapine_final_test() {

    read "houses.csv" as raw
    print raw
    stats raw

    http read "https://randomuser.me/api/?results=3" as json as users
    print users

    let min_price = 200000
    filter raw where price >= min_price as affordable
    filter affordable where bedrooms >= 3 as big
    filter big where bathrooms >= 2 as nice

    mutate nice add doubled = double(price) as m1
    mutate m1 add ppsf = price / sqft as m2
    mutate m2 add label = concat("Home ", bedrooms, "BR ", bathrooms, "BA") as m3

    sort m3 by price desc as sorted
    limit sorted 3 as top

    group m3 by bedrooms [
        count(label) as homes,
        avg(price) as avg_price,
        min(price) as cheapest
    ] as grouped

    sort grouped by homes desc as final

    train raw predict price using linear_regression as lr_model
    predict raw using lr_model as predicted

    select bedrooms, bathrooms, sqft, price, prediction from predicted as ml_results

    print final
    print ml_results

    write final into "final_output.json"
    write ml_results into "ml_output.json"
    excel write final into "final_output.xlsx"
    chart final homes by bedrooms as bar into "final_chart.html"

}